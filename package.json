{
  "name": "petri-dish",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1",
    "sim:report": "tsx scripts/sim-report.ts",
    "sim:report:smoke": "npm run sim:report -- --seed mythic-lagoon-17 --generations 120 --width 24 --height 14 --population 80",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.22.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
